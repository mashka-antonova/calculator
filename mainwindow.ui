  <property name="styleSheet">
   <string notr="true">/* Основной фон - Глубокий темный графит (#222223) */
QWidget#centralwidget {
    background-color: #121213;
}

/* Экран - Эффект чистого матового стекла с кремовым текстом */
QLineEdit#display {
    background-color: rgba(255, 254, 236, 0.05); /* Прозрачный крем */
    border: 1px solid rgba(255, 254, 236, 0.15);
    border-radius: 12px;
    color: #FFFEEC; /* Светлый крем из палитры */
    font-family: &quot;Segoe UI Light&quot;, sans-serif;
    font-size: 38px;
    padding: 10px;
}

/* Общий стиль для кнопок цифр */
QPushButton {
    background-color: rgba(255, 254, 236, 0.03);
    border: 1px solid rgba(255, 254, 236, 0.08);
    border-radius: 10px;
    color: #FFFEEC;
    font-family: &quot;Segoe UI Semibold&quot;;
    font-size: 16px;
    padding: 8px;
}

/* Эффект наведения - Яркое лавандовое свечение */
QPushButton:hover {
    background-color: rgba(188, 180, 255, 0.2); /* Сделали ярче */
    border: 1px solid rgba(188, 180, 255, 0.5); /* Рамка стала отчетливее */
    color: #BCB4FF;
}

/* Эффект нажатия */
QPushButton:pressed {
    background-color: #0A0A0A;
}

/* --- ОПЕРАТОРЫ (+ - * /) --- 
Яркий лавандовый акцент (#BCB4FF) */
QPushButton[text=&quot;+&quot;], QPushButton[text=&quot;-&quot;], 
QPushButton[text=&quot;*&quot;], QPushButton[text=&quot;/&quot;] {
    color: #BCB4FF;
    background-color: rgba(188, 180, 255, 0.15); /* Фон стал плотнее */
    border: 1px solid rgba(188, 180, 255, 0.4); /* Контур стал ярче */
    font-weight: bold;
    font-size: 20px;
}
QPushButton[text=&quot;+&quot;]:hover, QPushButton[text=&quot;-&quot;]:hover, 
QPushButton[text=&quot;*&quot;]:hover, QPushButton[text=&quot;/&quot;]:hover {
    background-color: rgba(188, 180, 255, 0.25);
}

/* --- КНОПКА РАВНО --- 
Главный неоновый акцент - Горчичный (#CAC426) */
QPushButton[text=&quot;=&quot;] {
    background-color: #CAC426;
    color: #222223; /* Темный текст для максимального контраста */
    border: none;
    font-weight: bold;
    font-size: 24px;
}
QPushButton[text=&quot;=&quot;]:hover {
    background-color: #DED94C; /* Чуть светлее при наведении */
}

/* --- УДАЛЕНИЕ И ОЧИСТКА (C, Del) --- */
QPushButton[text=&quot;C&quot;], QPushButton[text=&quot;⌫&quot;], QPushButton[text=&quot;Del&quot;] {
    color: #CAC426;
    border: 1px solid rgba(202, 196, 38, 0.4);
}
QPushButton[text=&quot;C&quot;]:hover, QPushButton[text=&quot;⌫&quot;]:hover, QPushButton[text=&quot;Del&quot;]:hover {
    background-color: rgba(202, 196, 38, 0.1);
}

/* --- НАУЧНЫЕ ФУНКЦИИ И ПАМЯТЬ --- 
Яркий лавандовый текст, чтобы не терялись на фоне */
QPushButton[text=&quot;sin&quot;], QPushButton[text=&quot;cos&quot;], QPushButton[text=&quot;tg&quot;], 
QPushButton[text=&quot;ctg&quot;], QPushButton[text=&quot;sqrt&quot;], QPushButton[text=&quot;1/x&quot;],
QPushButton[text=&quot;(&quot;], QPushButton[text=&quot;)&quot;],
QPushButton[text=&quot;M+&quot;], QPushButton[text=&quot;M-&quot;], QPushButton[text=&quot;MR&quot;], QPushButton[text=&quot;MC&quot;],
QPushButton[text=&quot;⮌&quot;], QPushButton[text=&quot;⮎&quot;], QPushButton[text=&quot;Undo&quot;], QPushButton[text=&quot;Redo&quot;] {
    color: rgba(188, 180, 255, 0.9); /* Почти 100% яркость текста */
    background-color: rgba(188, 180, 255, 0.05); /* Легчайшая заливка */
    border: 1px solid rgba(188, 180, 255, 0.15);
    font-size: 13px;
}
QPushButton[text=&quot;sin&quot;]:hover, QPushButton[text=&quot;cos&quot;]:hover, QPushButton[text=&quot;tg&quot;]:hover, 
QPushButton[text=&quot;ctg&quot;]:hover, QPushButton[text=&quot;sqrt&quot;]:hover, QPushButton[text=&quot;1/x&quot;]:hover,
QPushButton[text=&quot;(&quot;]:hover, QPushButton[text=&quot;)&quot;]:hover,
QPushButton[text=&quot;M+&quot;]:hover, QPushButton[text=&quot;M-&quot;]:hover, QPushButton[text=&quot;MR&quot;]:hover, QPushButton[text=&quot;MC&quot;]:hover,
QPushButton[text=&quot;⮌&quot;]:hover, QPushButton[text=&quot;⮎&quot;]:hover, QPushButton[text=&quot;Undo&quot;]:hover, QPushButton[text=&quot;Redo&quot;]:hover {
    background-color: rgba(188, 180, 255, 0.15);
}</string>
